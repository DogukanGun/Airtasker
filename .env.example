# ─── Network ────────────────────────────────────────────────────────
# LOCAL ANVIL (default):
RPC_URL=http://localhost:8545
CHAIN_ID=31337
#
# KITE TESTNET — fill in from official Kite Chain docs:
# RPC_URL=https://<kite-testnet-rpc>
# CHAIN_ID=<kite-testnet-chain-id>

# ─── Deployment output file (used by contracts/script/Deploy.s.sol) ─
# Default writes contracts/deployments/local.json. For testnet:
# DEPLOYMENT_FILE=deployments/kite-testnet.json

# ─── Deployed contract addresses (filled in after Deploy.s.sol) ─────
TASK_REGISTRY_ADDRESS=
TASK_ESCROW_ADDRESS=
KITE_PASSPORT_ADDRESS=
# Leave USDC_ADDRESS blank for local to auto-deploy MockUSDC.
# On testnet: paste the real testnet USDC address if Kite has one.
USDC_ADDRESS=

# ─── API ─────────────────────────────────────────────────────────────
API_PORT=3001
# Used as both deployer (TaskRegistry owner) AND API signer for triggerCompletion.
# LOCAL: anvil account #0 is fine: 0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# TESTNET: generate a fresh wallet and fund from the Kite faucet. Never reuse anvil keys on testnet.
API_WALLET_PRIVATE_KEY=
# BIP-32 root for per-task session keys (path m/44'/60'/0'/{taskId}'/0).
# LOCAL: anvil default works: "test test test test test test test test test test test junk"
# TESTNET: use the mnemonic of the new wallet above (or any independent 12-word phrase you control).
MASTER_MNEMONIC=

# ─── IPFS ────────────────────────────────────────────────────────────
# LOCAL: docker-compose starts an IPFS node at :5001.
# TESTNET: clear IPFS_API_URL and set PINATA_JWT instead.
IPFS_API_URL=http://localhost:5001
PINATA_JWT=

# ─── Auth ────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production

# ─── Agent LLM ───────────────────────────────────────────────────────
# Default provider is OpenAI (see agents/worker/nodes/execute.py).
# Set OPENAI_API_KEY to enable real execution; leave blank for stub mode.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional fallback (requires swapping execute.py to ChatAnthropic):
ANTHROPIC_API_KEY=
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false

# ─── Platform fees (raw 6-decimal USDC units) ────────────────────────
PLATFORM_FEE_BPS=250
SUBMISSION_FEE_USDC=100000
REVIEW_FEE_USDC=50000
